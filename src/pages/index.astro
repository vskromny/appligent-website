---
import Layout from '../layouts/Layout.astro';

const navLinks = [
  { label: 'Home', href: '#home' },
  { label: 'Expertise', href: '#expertise' },
  { label: 'How We Help', href: '#process' },
  { label: 'Register', href: '#register' },
];

const servicePillars = [
  { title: 'AI Automation', copy: 'Deploy trustworthy automation across ops, finance, and CX workflows.' },
  { title: 'Setup & Integration', copy: 'Connect models, APIs, and data pipelines to your existing systems.' },
  { title: 'AI Solution Implementation', copy: 'Ship custom copilots, assistants, or scoring systems with guardrails.' },
  { title: 'Data & AI Strategy', copy: 'Translate business goals into measurable AI roadmaps and KPIs.' },
  { title: 'Mobile Development', copy: 'Native iOS, Android, and web apps that extend your AI stack into the field.' },
  { title: 'Support & Refactoring', copy: 'Stabilize legacy apps, tighten infra, and keep releases humming.' },
  { title: 'Rapid App Prototyping', copy: 'Weekend-ready prototypes for stakeholder demos and validation.' },
];

const processSteps = [
  { label: 'Discover', detail: 'Deep-dive workshop, current-state audit, success definition.', duration: 'Week 1' },
  { label: 'Architect', detail: 'Flows, data touchpoints, KPIs, and technical plan locked.', duration: 'Week 2' },
  { label: 'Build', detail: 'Sprint-sized increments with continuous demos + telemetry.', duration: 'Weeks 3-6' },
  { label: 'Support', detail: 'Handover, docs, and optional ops-on-retainer.', duration: 'Ongoing' },
];

const proof = {
  quote: '“Appligent distilled months of experimentation into a polished AI workflow in under six weeks.”',
  author: 'Klara F., COO at SwissTrade',
  stats: [
    { label: 'Apps shipped', value: '45+' },
    { label: 'Automation ROI', value: '4.2x' },
    { label: 'Avg. sprint', value: '10 days' },
  ],
};

const year = new Date().getFullYear();
---
<Layout title="Appligent AI — AI Automation & Mobile Studio">
  <main class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <header id="home" class="section-shell pb-2">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <div class="h-12 w-12 rounded-2xl bg-white shadow-md flex items-center justify-center text-lg font-semibold text-slate-900">AA</div>
          <div>
            <p class="text-sm uppercase tracking-[0.3em] text-slate-500">Zurich · SME focused</p>
            <h1 class="text-4xl sm:text-5xl lg:text-[56px] font-semibold text-slate-900 max-w-2xl mt-4">AI automation & mobile execution without enterprise drag.</h1>
          </div>
        </div>
        <nav class="w-full sm:w-auto">
          <ul class="flex flex-wrap items-center gap-3 text-sm font-medium text-slate-600 justify-end">
            {navLinks.map((link) => (
              <li><a class="px-4 py-2 rounded-full hover:bg-white/70" href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </nav>
      </div>
      <div class="mt-10 grid gap-8 lg:grid-cols-[3fr,2fr] items-center">
        <div class="space-y-6">
          <p class="text-lg text-slate-600 max-w-xl">One-person studio delivering AI automation, integrations, and native apps for Swiss SMEs. Tight scope, transparent timelines, obsessive quality.</p>
          <div class="flex flex-wrap gap-3">
            <a class="btn-primary" href="#register" data-event="cta_click" data-location="hero">Start a project</a>
            <a class="btn-secondary" href="#expertise">See capabilities</a>
          </div>
          <div class="flex gap-6 text-sm text-slate-500">
            <div>
              <p class="text-2xl font-semibold text-slate-900">14+</p>
              <p>years shipping mobile + AI</p>
            </div>
            <div>
              <p class="text-2xl font-semibold text-slate-900">2-6 wks</p>
              <p>from kickoff to launch</p>
            </div>
          </div>
        </div>
        <div class="hero-visual p-8 flex flex-col justify-between">
          <div>
            <p class="text-sm uppercase tracking-[0.4em] text-slate-500">Stack</p>
            <p class="mt-2 text-lg text-slate-700">OpenAI · Anthropic · Firebase · Plausible · GitHub Actions</p>
          </div>
          <div class="text-right">
            <p class="text-slate-500 text-sm">Next deployment in</p>
            <p class="text-4xl font-semibold text-slate-900">03:14:27</p>
          </div>
        </div>
      </div>
    </header>

    <section id="expertise" class="section-shell">
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
        <div>
          <p class="text-sm uppercase tracking-[0.35em] text-slate-500">Expertise</p>
          <h2 class="text-3xl sm:text-4xl font-semibold mt-4">The stack we deploy for you</h2>
        </div>
        <p class="max-w-md text-slate-600">Seven modules you can mix to match your roadmap. Each engagement is scoped to outcomes, not vanity deliverables.</p>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {servicePillars.map((pillar) => (
          <article class="card" data-event="service_card">
            <div class="flex items-center justify-between">
              <h3 class="text-2xl font-semibold text-slate-900">{pillar.title}</h3>
              <span class="text-sm uppercase tracking-[0.25em] text-slate-400">{pillar.title.split(' ')[0]}</span>
            </div>
            <p class="mt-3 text-slate-600">{pillar.copy}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="process" class="section-shell">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6">
        <div>
          <p class="text-sm uppercase tracking-[0.35em] text-slate-500">How we help</p>
          <h2 class="text-3xl sm:text-4xl font-semibold mt-4">Clarity first, sprints second</h2>
        </div>
        <p class="max-w-md text-slate-600">Every builder-friendly project gets a plan, telemetry, and an exit ramp. No retainers without proof.</p>
      </div>
      <div class="mt-10 grid gap-4 lg:grid-cols-4">
        {processSteps.map((step, index) => (
          <div class="card relative" data-event="process_step">
            <span class="absolute -top-4 left-6 text-sm font-semibold text-slate-400">0{index + 1}</span>
            <h3 class="text-xl font-semibold text-slate-900 mt-4">{step.label}</h3>
            <p class="mt-3 text-slate-600">{step.detail}</p>
            <p class="mt-4 text-sm font-medium text-slate-500">{step.duration}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="section-shell">
      <div class="grid gap-8 lg:grid-cols-[3fr,2fr] items-center">
        <div class="card">
          <p class="text-sm uppercase tracking-[0.35em] text-slate-500">Proof</p>
          <p class="mt-4 text-2xl text-slate-900">{proof.quote}</p>
          <p class="mt-4 text-sm font-medium text-slate-500">{proof.author}</p>
        </div>
        <div class="grid grid-cols-3 gap-4 text-center">
          {proof.stats.map((stat) => (
            <div class="py-6 rounded-xl bg-white shadow-sm">
              <p class="text-3xl font-semibold text-slate-900">{stat.value}</p>
              <p class="text-sm text-slate-500">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section-shell" aria-labelledby="cta-band">
      <div class="gradient-band" id="cta-band">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
          <div>
            <p class="text-sm uppercase tracking-[0.35em]">Need a trusted partner?</p>
            <h2 class="text-3xl font-semibold mt-3 text-white max-w-2xl">Let’s turn your “what if we automated this?” into production code.</h2>
          </div>
          <a class="btn-primary bg-white text-slate-900" href="#register" data-event="cta_click" data-location="cta-band">Book a working session</a>
        </div>
      </div>
    </section>

    <section id="register" class="section-shell" aria-labelledby="lead-form">
      <div class="grid gap-8 lg:grid-cols-2">
        <div>
          <p class="text-sm uppercase tracking-[0.35em] text-slate-500">Register</p>
          <h2 id="lead-form" class="text-3xl sm:text-4xl font-semibold mt-4">Tell me what you’re building</h2>
          <p class="mt-4 text-slate-600">Email required, everything else optional. I’ll respond within one working day with next steps or clarifying questions.</p>
          <ul class="mt-6 space-y-3 text-slate-600">
            <li>• Emails routed securely, nothing shared with third parties.</li>
            <li>• Consent checkbox required to send.</li>
            <li>• GDPR-compliant privacy notice in footer.</li>
          </ul>
        </div>
        <div class="card">
          <form id="leadCapture" class="space-y-4" aria-live="polite">
            <label class="block text-sm font-medium text-slate-700">Email *</label>
            <input type="email" name="email" required class="w-full rounded-xl border border-[var(--clr-border)] px-4 py-3" placeholder="you@company.ch" />
            <label class="block text-sm font-medium text-slate-700">Company</label>
            <input type="text" name="company" class="w-full rounded-xl border border-[var(--clr-border)] px-4 py-3" placeholder="Acme AG" />
            <label class="block text-sm font-medium text-slate-700">Name</label>
            <input type="text" name="name" class="w-full rounded-xl border border-[var(--clr-border)] px-4 py-3" placeholder="Vlad" />
            <label class="block text-sm font-medium text-slate-700">Location</label>
            <input type="text" name="location" class="w-full rounded-xl border border-[var(--clr-border)] px-4 py-3" placeholder="Zurich" />
            <label class="block text-sm font-medium text-slate-700">What do you need?</label>
            <textarea name="notes" rows="4" class="w-full rounded-xl border border-[var(--clr-border)] px-4 py-3" placeholder="AI assistant for support ops, mobile companion app, etc."></textarea>
            <label class="flex gap-3 text-sm text-slate-600">
              <input type="checkbox" name="consent" required />
              I agree to be contacted about Appligent AI services & privacy terms.
            </label>
            <button class="btn-primary w-full" type="submit">Submit</button>
            <p id="formMessage" class="text-sm text-slate-500"></p>
          </form>
        </div>
      </div>
    </section>
  </main>

  <footer class="px-4 py-10 bg-white border-t border-[var(--clr-border)] text-sm text-slate-500">
    <div class="mx-auto max-w-6xl flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <p>© {year} Appligent AI · Zurich, Switzerland</p>
      <div class="flex gap-4">
        <a href="mailto:vlad@appligent.ai">vlad@appligent.ai</a>
        <a href="#">Privacy</a>
        <a href="#">Impressum</a>
      </div>
    </div>
  </footer>

  <script is:inline>
    const form = document.getElementById('leadCapture');
    const message = document.getElementById('formMessage');
    if (form) {
      form.addEventListener('submit', (event) => {
        event.preventDefault();
        const consent = form.querySelector('input[name="consent"]').checked;
        if (!consent) {
          message.textContent = 'Consent required to submit.';
          message.className = 'text-sm text-red-600';
          return;
        }
        message.textContent = 'Thanks! I’ll reply within one business day.';
        message.className = 'text-sm text-green-600';
        form.reset();
        form.querySelector('button').disabled = true;
        setTimeout(() => {
          form.querySelector('button').disabled = false;
        }, 2000);
      });
    }
  </script>
</Layout>
